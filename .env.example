# Listening address (default: :8080)
ADDR=:8080

# Postgres connection URL (required)
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/identity?sslmode=disable

# Whether to set Secure flag on cookies. Set to "false" for local http dev only.
COOKIE_SECURE=true

# Session absolute TTL (hours). 168 = 7 days.
SESSION_TTL_HOURS=168

# argon2id parameters
ARGON2_MEMORY_KIB=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=1

# CSRF allow-list for mutating requests (comma-separated, exact scheme+host[:port]).
# Required: the server refuses to start if empty. Vite dev server defaults to 5173.
ALLOWED_ORIGINS=http://localhost:5173

# Valkey (Redis wire-compatible) session cache. Required per ADR-0008.
# Local dev: redis://localhost:6379/0
# DO managed: rediss://default:<password>@<host>:25061/0
VALKEY_URL=redis://localhost:6379/0

# Connection establishment deadline (ms). Default 200.
VALKEY_DIAL_TIMEOUT_MS=200

# Per-operation deadline (ms) applied to Set/Get/Delete. Default 100.
VALKEY_OP_TIMEOUT_MS=100
